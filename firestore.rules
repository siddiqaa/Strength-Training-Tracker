rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Workout
    function isValidWorkout(data) {
      return data.userId == request.auth.uid
        && data.exerciseName is string && data.exerciseName.size() > 0 && data.exerciseName.size() <= 100
        && data.weight is number && data.weight >= 0
        && data.set1 is number && data.set1 >= 0
        && data.set2 is number && data.set2 >= 0
        && (!('set3' in data) || data.set3 == null || (data.set3 is number && data.set3 >= 0))
        && data.intensity in ['Heavy', 'Light', 'Medium']
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500))
        && (!('targetWeight' in data) || data.targetWeight == null || data.targetWeight is number)
        && (!('targetReps' in data) || data.targetReps == null || data.targetReps is string)
        && (!('targetSets' in data) || data.targetSets == null || data.targetSets is number)
        && data.date is timestamp;
    }

    match /workouts/{workoutId} {
      allow create: if isSignedIn() 
        && isValidWorkout(incoming())
        && incoming().keys().hasAll(['userId', 'exerciseName', 'weight', 'set1', 'set2', 'intensity', 'date'])
        && incoming().keys().size() <= 12; // Including optional set3, notes and targets

      allow read: if request.auth != null && request.auth.uid == resource.data.userId;

      allow update: if request.auth != null && request.auth.uid == resource.data.userId
        && isValidWorkout(incoming())
        && incoming().userId == resource.data.userId // Immutable userId
        && incoming().diff(resource.data).affectedKeys().hasOnly(['exerciseName', 'weight', 'set1', 'set2', 'set3', 'intensity', 'notes', 'targetWeight', 'targetReps', 'targetSets', 'date']);

      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    match /userPlans/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
